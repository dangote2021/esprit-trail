# ====== TRAILQUEST — Variables d'environnement ======
# Copier en .env.local et remplir.

# Supabase — créer un projet sur supabase.com puis copier URL + anon key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role (server-only — ne JAMAIS exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# OAuth Strava — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
NEXT_PUBLIC_STRAVA_REDIRECT_URI=http://localhost:3000/api/oauth/strava/callback

# OAuth Garmin Connect — https://developer.garmin.com/gc-developer-program/overview/
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# OAuth COROS — contact developer@coros.com pour access
COROS_CLIENT_ID=
COROS_CLIENT_SECRET=

# OAuth Suunto — https://apizone.suunto.com/how-to-access
SUUNTO_CLIENT_ID=
SUUNTO_CLIENT_SECRET=

# Claude API — pour le coach IA
ANTHROPIC_API_KEY=

# UTMB API (privée — demande à utmb@ipbd.fr pour partenariat)
UTMB_API_KEY=
